{
    "name": "file-manager",
    "version": "1.0.0",
    "description": "File Manager for MD and PDF files with MongoDB",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "rm -rf dist && tsc",
        "seed": "tsx src/utils/seeder.ts"
    },
    "keywords": [
        "file-manager",
        "mongodb",
        "markdown",
        "pdf"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "archiver": "^7.0.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "ejs": "^5.0.1",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^7.5.0",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "@types/archiver": "^7.0.0",
        "@types/bcryptjs": "^2.4.4",
        "@types/cors": "^2.8.14",
        "@types/ejs": "^3.1.5",
        "@types/express": "^4.17.17",
        "@types/jsonwebtoken": "^9.0.3",
        "@types/multer": "^1.4.7",
        "@types/node": "^20.5.9",
        "@typescript-eslint/eslint-plugin": "^6.5.0",
        "@typescript-eslint/parser": "^6.5.0",
        "eslint": "^8.48.0",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "nodemon": "^3.0.1",
        "prettier": "^3.0.3",
        "ts-node": "^10.9.1",
        "tsx": "^4.21.0",
        "typescript": "^5.2.2"
    }
}
