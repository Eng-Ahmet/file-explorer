<!DOCTYPE html>
<html lang="en" class="dark bg-[#0F172A]" style="background-color: #0F172A; color-scheme: dark;">

<head>
    <title>User & Permissions - Hwai Technology</title>
    <%- include('../partials/head') %>
        <%- include('../partials/auth-guard', { requireAdmin: true }) %>
</head>

<body class="flex flex-col h-screen overflow-hidden bg-[#0F172A] text-slate-200">
    <%- include('../partials/header', { isAdminPage: true }) %>

        <main class="flex-1 overflow-y-auto relative flex">
            <!-- Sidebar Backdrop (Mobile Only) -->
            <div id="sidebarOverlay"
                class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-[55] hidden lg:hidden transition-opacity duration-300 opacity-0 cursor-pointer">
            </div>

            <!-- Sidebar -->
            <aside id="sidebar"
                class="fixed lg:relative inset-y-0 left-0 w-72 border-r border-white/10 glass overflow-y-auto custom-scrollbar flex flex-col p-6 gap-8 z-[60] transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
                <div class="lg:hidden flex justify-end mb-2">
                    <button id="closeMenuBtn" class="p-2 text-slate-500 hover:text-white transition-colors">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <%- include('../partials/sidebar-nav') %>
            </aside>

            <div class="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar bg-slate-900/50">
                <div class="max-w-6xl mx-auto space-y-6 md:space-y-8">
                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                        <div>
                            <h2 class="text-2xl md:text-3xl font-bold">Operational Intelligence Dashboard</h2>
                            <p class="text-slate-500 text-sm mt-1">Real-time system monitoring and global metrics.</p>
                        </div>
                        <div class="flex flex-wrap items-center gap-3">
                            <a href="/admin/projects"
                                class="flex items-center gap-2 bg-tech-blue hover:bg-blue-600 text-white px-4 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest transition-all shadow-lg shadow-tech-blue/20">
                                <i class="fas fa-project-diagram"></i>
                                <span>Project Intelligence</span>
                            </a>
                            <button id="syncStorageBtn"
                                class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest transition-all shadow-lg shadow-indigo-600/20 active:scale-95">
                                <i class="fas fa-arrows-rotate"></i>
                                <span>Sync Storage</span>
                            </button>
                            <div id="systemStatus"
                                class="flex items-center gap-3 glass px-4 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest text-tech-blue">
                                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                                Online
                            </div>
                        </div>
                    </div>

                    <!-- Analytics Cards -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- ... Analytics Cards Content ... -->
                        <div
                            class="glass p-6 rounded-[2.5rem] space-y-4 hover:border-tech-blue/30 transition-all duration-300 group">
                            <div class="flex items-center justify-between">
                                <span class="text-slate-500 text-[10px] font-extrabold uppercase tracking-[0.2em]">Total
                                    Users</span>
                                <div
                                    class="w-12 h-12 rounded-2xl bg-tech-blue/10 flex items-center justify-center text-tech-blue shadow-inner group-hover:scale-110 transition-transform">
                                    <i class="fas fa-users text-xl"></i>
                                </div>
                            </div>
                            <div>
                                <div id="totalUsersCard" class="text-3xl font-bold text-white">0</div>
                                <div class="text-[10px] text-slate-600 font-bold uppercase tracking-widest mt-1">
                                    Verified
                                    Accounts</div>
                            </div>
                        </div>
                        <div
                            class="glass p-6 rounded-[2.5rem] space-y-4 hover:border-amber-500/30 transition-all duration-300 group">
                            <div class="flex items-center justify-between">
                                <span
                                    class="text-slate-500 text-[10px] font-extrabold uppercase tracking-[0.2em]">Storage
                                    Used</span>
                                <div
                                    class="w-12 h-12 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-500 shadow-inner group-hover:scale-110 transition-transform">
                                    <i class="fas fa-database text-xl"></i>
                                </div>
                            </div>
                            <div>
                                <div id="totalStorageCard" class="text-3xl font-bold text-white">0 MB</div>
                                <div id="storagePercentLabel"
                                    class="text-[10px] text-slate-600 font-bold uppercase tracking-widest mt-1 truncate">
                                    0%
                                    Capacity</div>
                            </div>
                        </div>
                        <div
                            class="glass p-6 rounded-[2.5rem] space-y-4 hover:border-rose-500/30 transition-all duration-300 group">
                            <div class="flex items-center justify-between">
                                <span class="text-slate-500 text-[10px] font-extrabold uppercase tracking-[0.2em]">CPU
                                    Status</span>
                                <div
                                    class="w-12 h-12 rounded-2xl bg-rose-500/10 flex items-center justify-center text-rose-500 shadow-inner group-hover:scale-110 transition-transform">
                                    <i class="fas fa-microchip text-xl"></i>
                                </div>
                            </div>
                            <div>
                                <div id="cpuLoadCard" class="text-3xl font-bold text-white">0%</div>
                                <div class="text-[10px] text-slate-600 font-bold uppercase tracking-widest mt-1">
                                    Real-time
                                    Load</div>
                            </div>
                        </div>
                        <div
                            class="glass p-6 rounded-[2.5rem] space-y-4 hover:border-indigo-500/30 transition-all duration-300 group">
                            <div class="flex items-center justify-between">
                                <span
                                    class="text-slate-500 text-[10px] font-extrabold uppercase tracking-[0.2em]">Memory</span>
                                <div
                                    class="w-12 h-12 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-indigo-500 shadow-inner group-hover:scale-110 transition-transform">
                                    <i class="fas fa-memory text-xl"></i>
                                </div>
                            </div>
                            <div>
                                <div id="ramUsageCard" class="text-3xl font-bold text-white">0%</div>
                                <div id="ramDetailLabel"
                                    class="text-[10px] text-slate-600 font-bold uppercase tracking-widest mt-1">
                                    Allocation
                                    Check</div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Activity -->
                    <div class="glass p-8 rounded-[2.5rem] border border-white/5 shadow-xl flex flex-col h-[500px]">
                        <div class="flex items-center justify-between mb-6 flex-shrink-0">
                            <h2 class="text-xl font-bold flex items-center gap-3">
                                <i class="fas fa-list-ul text-tech-blue"></i>
                                Recent Intelligence Logs
                                <span
                                    class="bg-white/5 text-slate-500 text-[10px] px-2 py-1 rounded-lg uppercase tracking-widest ml-2 border border-white/5">Today</span>
                            </h2>
                            <div class="flex items-center gap-2">
                                <button onclick="loadLogs()"
                                    class="w-9 h-9 rounded-xl bg-white/5 hover:bg-white/10 flex items-center justify-center text-slate-400 transition-all border border-white/5"
                                    title="Refresh Logs">
                                    <i class="fas fa-sync-alt text-xs"></i>
                                </button>
                                <button onclick="clearLogs()"
                                    class="w-9 h-9 rounded-xl bg-rose-500/10 hover:bg-rose-500/20 flex items-center justify-center text-rose-500 transition-all border border-rose-500/20"
                                    title="Purge System Logs">
                                    <i class="fas fa-terminal text-xs"></i>
                                </button>
                            </div>
                        </div>
                        <div id="activityList" class="flex-1 overflow-y-auto custom-scrollbar pr-2 space-y-4">
                            <div class="flex items-center justify-center h-full text-slate-500">
                                <div class="text-center">
                                    <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
                                    <p>Decrypting activity logs...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../partials/toast') %>
            <script src="/js/admin.js"></script>
            <script>
                window.allUsers = [];
            </script>
</body>

</html>