<!DOCTYPE html>
<html lang="en" class="dark bg-[#0F172A]" style="background-color: #0F172A; color-scheme: dark;">

<head>
    <title>Hwai Technology File System</title>
    <%- include('../partials/head') %>
        <%- include('../partials/auth-guard') %>
            <style>
                html:not(.ready) body {
                    opacity: 0;
                }

                body {
                    transition: opacity 0.3s ease-in-out;
                }
            </style>
</head>

<body class="font-sans antialiased h-screen overflow-hidden flex flex-col bg-[#0F172A] text-slate-200">
    <%- include('../partials/header', { isAdminPage: false }) %>

        <main class="flex-1 flex overflow-hidden relative">
            <!-- Sidebar Backdrop (Mobile Only) -->
            <div id="sidebarOverlay"
                class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-[55] hidden transition-opacity duration-300 opacity-0 cursor-pointer">
            </div>

            <!-- Right Sidebar Backdrop (Mobile Only) -->
            <div id="rightSidebarOverlay"
                class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-[55] hidden transition-opacity duration-300 opacity-0 cursor-pointer">
            </div>

            <!-- Sidebar -->
            <aside id="sidebar"
                class="fixed md:relative inset-y-0 left-0 w-72 border-r border-white/10 glass overflow-y-auto custom-scrollbar flex flex-col p-6 gap-8 z-[60] transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out">
                <div class="md:hidden flex justify-end mb-2">
                    <button id="closeMenuBtn" class="p-2 text-slate-500 hover:text-white transition-colors">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <%- include('../partials/sidebar-nav') %>
            </aside>

            <!-- Main Content -->
            <section class="flex-1 flex flex-col overflow-hidden bg-slate-900/50">
                <!-- Search & Actions Bar -->
                <%- include('../partials/search-bar') %>

                    <!-- Breadcrumbs -->
                    <div class="px-6 pb-4 flex items-center gap-3 overflow-x-auto whitespace-nowrap scrollbar-none">
                        <button id="goUpBtn"
                            class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white transition-all text-xs font-bold uppercase tracking-widest border border-white/5">
                            <i class="fas fa-arrow-up"></i>
                            <span class="hidden sm:inline">Up</span>
                        </button>
                        <div id="breadcrumbContainer" class="flex items-center gap-3 text-slate-500 text-sm"></div>
                    </div>

                    <!-- Content Area -->
                    <div class="flex-1 overflow-y-auto p-6 pt-0 custom-scrollbar relative">
                        <div id="filesContainer"
                            class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-3 md:gap-4">
                        </div>
                        <%- include('../partials/bulk-actions') %>

                            <!-- Empty State -->
                            <div id="emptyState"
                                class="hidden flex flex-col items-center justify-center py-20 opacity-50">
                                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mb-4">
                                    <i class="fas fa-microchip text-4xl text-slate-600"></i>
                                </div>
                                <h3 class="text-xl font-medium text-slate-400">Library Empty</h3>
                                <p class="text-slate-500 text-sm">Upload your technology documents to begin</p>
                            </div>
                    </div>
            </section>

            <!-- Right Sidebar (File Tree) -->
            <aside id="rightSidebar"
                class="fixed md:relative inset-y-0 right-0 w-72 border-l border-white/10 glass overflow-y-auto custom-scrollbar flex flex-col p-6 gap-8 z-[60] transform translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out bg-[#0F172A] shadow-[-10px_0_30px_rgba(0,0,0,0.5)]">
                <div class="flex items-center justify-between mb-2">
                    <button id="closeRightMenuBtn"
                        class="md:hidden p-2 text-slate-500 hover:text-white transition-colors">
                        <i class="fas fa-times text-md"></i>
                    </button>
                </div>
                <div class="flex-1 overflow-y-auto custom-scrollbar">
                    <%- include('../partials/right-sidebar') %>
                </div>
            </aside>
        </main>

        <%- include('../partials/modals') %>
            <%- include('../partials/toast') %>
                <%- include('../partials/storage-gauge') %>

                    <input type="file" id="fileInput" multiple accept="*" class="hidden">

                    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
                    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
                    <script src="/js/fileManager.js"></script>
                    <script src="/js/fileViewer.js"></script>
                    <script src="/js/app.js"></script>
                    <script>document.documentElement.classList.add('ready');</script>
</body>

</html>