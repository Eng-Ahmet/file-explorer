<!DOCTYPE html>
<html lang="en" class="dark bg-[#0F172A]" style="background-color: #0F172A; color-scheme: dark;">

<head>
    <title>User & Permissions - Hwai Technology</title>
    <%- include('../partials/head') %>
        <%- include('../partials/auth-guard', { requireAdmin: true }) %>
</head>

<body class="flex flex-col h-screen overflow-hidden bg-[#0F172A] text-slate-200">
    <%- include('../partials/header', { isAdminPage: true }) %>

        <main class="flex-1 overflow-y-auto relative flex">
            <!-- Sidebar Backdrop (Mobile Only) -->
            <div id="sidebarOverlay"
                class="fixed inset-0 bg-slate-950/80 backdrop-blur-sm z-[55] hidden lg:hidden transition-opacity duration-300 opacity-0 cursor-pointer">
            </div>

            <!-- Sidebar -->
            <aside id="sidebar"
                class="fixed lg:relative inset-y-0 left-0 w-72 border-r border-white/10 glass overflow-y-auto custom-scrollbar flex flex-col p-6 gap-8 z-[60] transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
                <div class="lg:hidden flex justify-end mb-2">
                    <button id="closeMenuBtn" class="p-2 text-slate-500 hover:text-white transition-colors">
                        <i class="fas fa-times text-xl"></i>
                    </button>
                </div>
                <%- include('../partials/sidebar-nav') %>
            </aside>

            <div class="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar bg-slate-900/50">
                <div class="max-w-6xl mx-auto space-y-6 md:space-y-8">
                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                        <div>
                            <h2 class="text-2xl md:text-3xl font-bold">User & Permissions Matrix</h2>
                            <p class="text-slate-500 text-sm mt-1">Manage personnel access levels and operational
                                clearance.</p>
                        </div>
                        <div class="flex flex-wrap items-center gap-3">
                            <a href="/admin/projects"
                                class="flex items-center gap-2 bg-tech-blue hover:bg-blue-600 text-white px-4 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest transition-all shadow-lg shadow-tech-blue/20">
                                <i class="fas fa-project-diagram"></i>
                                <span>Project Intelligence</span>
                            </a>
                            <button id="syncStorageBtn"
                                class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest transition-all shadow-lg shadow-indigo-600/20 active:scale-95">
                                <i class="fas fa-arrows-rotate"></i>
                                <span>Sync Storage</span>
                            </button>
                            <div id="systemStatus"
                                class="flex items-center gap-3 glass px-4 py-2 rounded-xl text-[10px] md:text-xs font-bold uppercase tracking-widest text-tech-blue">
                                <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                                Online
                            </div>
                        </div>
                    </div>

                 
                    <!-- Search and Filter Bar -->
                    <div class="glass p-3 rounded-[2rem] border border-white/5 shadow-2xl">
                        <div class="flex flex-col lg:flex-row gap-4 items-center">
                            <div class="relative flex-1 w-full group">
                                <i
                                    class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-500 group-focus-within:text-tech-blue transition-colors text-sm"></i>
                                <input type="text" id="userSearchInput"
                                    placeholder="Search systems or administrators..."
                                    class="w-full bg-white/5 border border-transparent focus:border-white/10 focus:bg-white/10 rounded-2xl pl-14 pr-4 py-4 text-sm text-white placeholder:text-slate-600 transition-all outline-none">
                            </div>
                            <!-- ... Filters ... -->
                            <div class="flex flex-wrap items-center gap-3 w-full lg:w-auto">
                                <div class="flex items-center gap-2 bg-white/5 p-1.5 rounded-2xl border border-white/5">
                                    <select id="roleFilter"
                                        class="bg-transparent border-none text-xs font-bold text-slate-400 focus:ring-0 cursor-pointer pr-8">
                                        <option value="all" class="bg-slate-900">All Levels</option>
                                        <option value="admin" class="bg-slate-900">Admins</option>
                                        <option value="user" class="bg-slate-900">Standard</option>
                                    </select>
                                    <div class="w-px h-4 bg-white/10 mx-1"></div>
                                    <select id="statusFilter"
                                        class="bg-transparent border-none text-xs font-bold text-slate-400 focus:ring-0 cursor-pointer pr-8">
                                        <option value="all" class="bg-slate-900">All Status</option>
                                        <option value="active" class="bg-slate-900">Activated</option>
                                        <option value="disabled" class="bg-slate-900">Disabled</option>
                                    </select>
                                </div>
                                <button id="refreshStatsBtn"
                                    class="w-14 h-14 flex items-center justify-center bg-tech-blue rounded-2xl text-white hover:bg-blue-600 transition-all shadow-lg shadow-tech-blue/20 active:scale-95 group">
                                    <i
                                        class="fas fa-sync-alt text-sm group-hover:rotate-180 transition-transform duration-700"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="glass rounded-[2.5rem] overflow-hidden shadow-2xl border border-white/5">
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr
                                        class="bg-white/5 border-b border-white/10 uppercase tracking-[0.2em] text-[10px] font-extrabold">
                                        <th class="px-8 py-6 text-slate-500">Identity</th>
                                        <th class="px-8 py-6 text-slate-500">Storage Usage</th>
                                        <th class="px-8 py-6 text-slate-500 text-center">Permissions</th>
                                        <th class="px-8 py-6 text-slate-500">Joined</th>
                                        <th class="px-8 py-6 text-slate-500 text-right">Control</th>
                                    </tr>
                                </thead>
                                <tbody id="usersTableBody" class="divide-y divide-white/5"></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('../partials/admin-modals') %>
            <%- include('../partials/toast') %>

                <script src="/js/admin.js"></script>
                <script>
                    // Use a global variable or object to store state if needed by external admin.js
                    window.allUsers = [];
                </script>
</body>

</html>