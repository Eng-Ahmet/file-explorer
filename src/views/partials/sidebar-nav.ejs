<script>
    // تمييز الرابط النشط بناءً على الصفحة الحالية
    function highlightActiveLink() {
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('.nav-link');

        navLinks.forEach(link => {
            const linkPage = link.getAttribute('data-page');

            if (linkPage === currentPath || (currentPath === '/' && linkPage === '/files')) {
                link.classList.add('active');
                link.classList.remove('text-slate-400');
                link.classList.remove('hover:text-white');
                link.classList.add('text-white');
                link.style.background = 'rgba(56, 189, 248, 0.1)';
                link.style.borderColor = 'rgba(56, 189, 248, 0.3)';
                link.querySelector('i').style.color = '#38bdf8';
            } else {
                link.classList.remove('active');
                link.classList.add('text-slate-400');
                link.style.background = '';
                link.style.borderColor = '';
            }
        });
    }

    // استدعي الدوال عند تحميل الصفحة
    document.addEventListener('DOMContentLoaded', () => {
        highlightActiveLink();

        // إظهار روابط الإدارة إذا كان المستخدم أدمن
        const storedUser = localStorage.getItem('user');
        if (storedUser) {
            try {
                const user = JSON.parse(storedUser);
                if (user.role === 'admin') {
                    const adminNav = document.getElementById('adminNavLinks');
                    if (adminNav) {
                        adminNav.classList.remove('hidden');

                        console.error('Error parsing user for sidebar:', e);
                    }
                }
            } catch (e) {
                console.error('Error parsing user from localStorage:', e);
            }
        }
    });

    // وأيضاً عند تغيير URL
    window.addEventListener('popstate', () => {
        highlightActiveLink();
    });
</script>