<div id="fileViewerModal" class="fixed inset-0 z-[100] hidden flex flex-col bg-slate-950">
    <header class="h-16 border-b border-white/10 flex items-center px-4 md:px-6 justify-between">
        <div class="flex items-center gap-3">
            <button onclick="document.getElementById('fileViewerModal').classList.add('hidden')"
                class="md:hidden flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 text-slate-400 hover:text-white transition-all text-xs font-bold uppercase tracking-widest border border-white/5">
                <i class="fas fa-arrow-left"></i>
                <span>Back</span>
            </button>
            <h2 id="fileViewerTitle" class="font-bold flex items-center gap-3">
                <i class="fas fa-file-lines text-tech-blue"></i>
                <span class="hidden sm:inline">File Preview</span>
            </h2>
        </div>
        <div class="flex items-center gap-3">
            <button id="printBtn"
                class="flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white px-4 py-1.5 rounded-lg text-sm font-medium transition-all">
                <i class="fas fa-print"></i>
                <span>Print</span>
            </button>
            <button id="downloadBtn"
                class="flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white px-4 py-1.5 rounded-lg text-sm font-medium transition-all">
                <i class="fas fa-download"></i>
                <span>Download</span>
            </button>
            <button id="editBtn"
                class="hidden items-center gap-2 bg-tech-blue/20 hover:bg-tech-blue/30 text-tech-blue px-4 py-1.5 rounded-lg text-sm font-medium transition-all border border-tech-blue/20">
                <i class="fas fa-edit"></i>
                <span>Edit</span>
            </button>
            <button id="saveBtn"
                class="hidden items-center gap-2 bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 px-4 py-1.5 rounded-lg text-sm font-medium transition-all border border-emerald-500/20">
                <i class="fas fa-save"></i>
                <span>Save</span>
            </button>
            <button id="cancelEditBtn"
                class="hidden items-center gap-2 bg-white/5 hover:bg-white/10 text-slate-400 px-4 py-1.5 rounded-lg text-sm font-medium transition-all">
                <span>Cancel</span>
            </button>
            <button onclick="document.getElementById('fileViewerModal').classList.add('hidden')"
                class="p-2 text-slate-400 hover:text-white hover:bg-white/10 rounded-lg transition-all">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
    </header>
    <div id="fileViewerContent" class="flex-1 overflow-auto bg-slate-900 custom-scrollbar"></div>
</div>

<div id="storageModal" class="fixed inset-0 z-[110] hidden flex items-center justify-center p-4">
    <div id="storageModalOverlay" class="absolute inset-0 bg-slate-950/80 backdrop-blur-md"></div>
    <div class="glass w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden relative animate-fade-in">
        <header class="p-6 border-b border-white/10 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-2xl bg-tech-blue/20 text-tech-blue flex items-center justify-center">
                    <i class="fas fa-chart-pie text-xl"></i>
                </div>
                <div>
                    <h2 class="font-bold text-lg text-white">Storage Analysis</h2>
                    <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Quota Management</p>
                </div>
            </div>
            <button id="closeStorageModal"
                class="p-2 text-slate-400 hover:text-white hover:bg-white/10 rounded-xl transition-all">
                <i class="fas fa-times text-xl"></i>
            </button>
        </header>
        <div class="p-8 space-y-8">
            <!-- Usage Overview -->
            <div class="space-y-4">
                <div class="flex justify-between items-end">
                    <div class="space-y-1">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Currently Used</span>
                        <h3 id="modalUsageValue" class="text-3xl font-bold text-white leading-none">0 KB</h3>
                    </div>
                    <div class="text-right space-y-1">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">Total Limit</span>
                        <h3 id="modalLimitValue" class="text-sm font-bold text-slate-300">100 MB</h3>
                    </div>
                </div>
                <div class="h-3 w-full bg-white/5 rounded-full overflow-hidden border border-white/5 p-0.5">
                    <div id="modalUsageBar"
                        class="h-full bg-tech-blue rounded-full transition-all duration-1000 shadow-[0_0_15px_rgba(56,189,248,0.5)]"
                        style="width: 0%"></div>
                </div>
            </div>

            <!-- Breakdown Cards -->
            <div class="grid grid-cols-2 gap-4">
                <div class="glass bg-white/[0.02] p-4 rounded-2xl space-y-2">
                    <div class="flex items-center gap-2 text-tech-blue">
                        <i class="fas fa-file-invoice text-xs"></i>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Total Files</span>
                    </div>
                    <div class="flex items-baseline gap-2">
                        <span id="totalFilesCount" class="text-xl font-bold text-white">0</span>
                        <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Items</span>
                    </div>
                </div>
                <div class="glass bg-white/[0.02] p-4 rounded-2xl space-y-2">
                    <div class="flex items-center gap-2 text-amber-500">
                        <i class="fas fa-folder-tree text-xs"></i>
                        <span class="text-[10px] font-bold uppercase tracking-widest">Total Folders</span>
                    </div>
                    <div class="flex items-baseline gap-2">
                        <span id="totalFoldersCount" class="text-xl font-bold text-white">0</span>
                        <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest">Groups</span>
                    </div>
                </div>
            </div>

            <!-- Footer Summary -->
            <div class="grid grid-cols-1 gap-4">
                <div class="p-4 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <div
                            class="w-10 h-10 rounded-xl bg-orange-500/10 text-orange-500 flex items-center justify-center">
                            <i class="fas fa-user-shield"></i>
                        </div>
                        <div class="space-y-0.5">
                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block">Access
                                Level</span>
                            <span id="modalUserRole"
                                class="text-xs font-bold text-white uppercase tracking-wider">Loading...</span>
                        </div>
                    </div>
                    <div class="text-right">
                        <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest block">System
                            Status</span>
                        <span class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest">Optimal</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Item Sharing Modal -->
<div id="shareItemModal" class="fixed inset-0 z-[160] hidden flex items-center justify-center p-4">
    <div onclick="closeShareItemModal()" class="absolute inset-0 bg-slate-950/80 backdrop-blur-md"></div>
    <div class="glass w-full max-w-lg rounded-[2.5rem] shadow-2xl overflow-hidden relative animate-fade-in border border-white/5">
        <header class="p-8 border-b border-white/10">
            <div class="flex items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-2xl bg-tech-blue/20 text-tech-blue flex items-center justify-center">
                        <i class="fas fa-share-nodes text-2xl"></i>
                    </div>
                    <div>
                        <h2 class="font-bold text-xl text-white">Share Access</h2>
                        <p id="shareItemSubtitle" class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mt-1">Authorize multiple users for collaborative access</p>
                    </div>
                </div>
                <button onclick="closeShareItemModal()" class="w-10 h-10 flex items-center justify-center text-slate-500 hover:text-white hover:bg-white/10 rounded-xl transition-all">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="mt-8 relative group">
                <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-500 group-focus-within:text-tech-blue transition-colors text-xs"></i>
                <input type="text" id="shareSearchInput" oninput="filterShareUsers()" placeholder="Search collaborators..." 
                    class="w-full bg-white/5 border border-white/10 focus:border-tech-blue/30 focus:bg-white/10 rounded-2xl pl-12 pr-4 py-4 text-sm text-white placeholder:text-slate-600 transition-all outline-none">
            </div>
        </header>

        <div class="px-8 pt-4">
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-tech-blue/60 mb-4">Active Collaborators</h3>
            <div id="activeCollaboratorsList" class="space-y-3 mb-6 empty:after:content-['No_active_collaborators'] empty:after:text-xs empty:after:text-slate-600 empty:after:italic">
                <!-- Active users with disconnect button -->
            </div>
            
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-4">Add Collaborators</h3>
        </div>
        <div id="shareUserList" class="p-6 pt-0 max-h-[300px] overflow-y-auto custom-scrollbar space-y-3">
            <!-- User items will be rendered here -->
        </div>

        <div class="p-8 bg-white/[0.02] border-t border-white/5 flex gap-4">
            <button onclick="closeShareItemModal()" class="flex-1 px-8 py-4 rounded-2xl bg-white/5 hover:bg-white/10 text-white text-sm font-bold transition-all border border-white/5">
                Discard
            </button>
            <button id="confirmShareBtn" class="flex-[2] px-8 py-4 rounded-2xl bg-tech-blue hover:bg-blue-600 text-white text-sm font-bold transition-all shadow-lg shadow-tech-blue/30 active:scale-[0.98]">
                Confirm Sharing
            </button>
        </div>
    </div>
</div>
