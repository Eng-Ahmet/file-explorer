<div class="flex flex-col gap-10">
    <!-- User Directories Section -->
    <section id="userDirectoriesSection" class="admin-only hidden">
        <div class="flex items-center mb-5 px-2">
            <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">User Directories</h2>
        </div>
        <div class="px-2 mb-8">
            <select id="userDirectorySelect"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-xs text-slate-300 focus:outline-none focus:border-tech-blue/50 transition-all appearance-none cursor-pointer">
                <option value="" disabled selected>Select User Directory...</option>
            </select>
        </div>
    </section>

    <!-- Inventory Section -->
    <section id="inventorySection" class="flex-1 min-h-0">
        <div class="flex items-center justify-between mb-5 px-2">
            <h2 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">Inventory</h2>
            <div class="flex items-center gap-1">
                <button onclick="if(window.appHandlers) window.appHandlers.uploadTrigger()"
                    class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-white/5 text-slate-500 hover:text-tech-blue transition-all border border-transparent hover:border-white/5"
                    title="Upload File">
                    <i class="fas fa-upload text-[10px]"></i>
                </button>
                <button onclick="if(window.appHandlers) window.appHandlers.createFile()"
                    class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-white/5 text-slate-500 hover:text-tech-blue transition-all border border-transparent hover:border-white/5"
                    title="New File">
                    <i class="fas fa-file-medical text-[10px]"></i>
                </button>
                <button onclick="if(window.appHandlers) window.appHandlers.createFolder()"
                    class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-white/5 text-slate-500 hover:text-tech-blue transition-all border border-transparent hover:border-white/5"
                    title="New Folder">
                    <i class="fas fa-folder-plus text-[10px]"></i>
                </button>
            </div>
        </div>

        <!-- Folder Tree Container -->
        <div id="sidebarFolderTree" class="space-y-1 min-h-[150px] overflow-y-auto max-h-[60vh] custom-scrollbar px-1">
            <div class="flex flex-col items-center justify-center py-10 opacity-20">
                <i class="fas fa-microchip fa-spin text-xl mb-2"></i>
                <span class="text-[8px] font-black uppercase tracking-widest">Scanning...</span>
            </div>
        </div>
    </section>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userSelect = document.getElementById('userDirectorySelect');
        const userDirsSection = document.getElementById('userDirectoriesSection');

        // Check if user is admin to show the section
        const storedUser = localStorage.getItem('user');
        if (storedUser) {
            try {
                const user = JSON.parse(storedUser);
                if (user.role === 'admin') {
                    if (userDirsSection) userDirsSection.classList.remove('hidden');
                    loadUserDirectories();
                }
            } catch (e) {
                console.error('Error parsing user for right-sidebar:', e);
            }
        }

        async function loadUserDirectories() {
            try {
                const response = await fetch('/api/admin/users', {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });
                const users = await response.json();

                if (userSelect && users.length > 0) {
                    userSelect.innerHTML = '<option value="" disabled selected>Select User Directory...</option>';
                    users.forEach(user => {
                        const option = document.createElement('option');
                        option.value = user.email;
                        option.textContent = user.email;
                        option.className = 'bg-[#0F172A] text-slate-300';
                        userSelect.appendChild(option);
                    });

                    // Add change listener to switch directory
                    userSelect.addEventListener('change', (e) => {
                        const email = e.target.value;
                        if (window.appHandlers && window.appHandlers.switchUserContext) {
                            window.appHandlers.switchUserContext(email);
                        } else {
                            console.warn('switchUserContext handler not found');
                        }
                    });
                }
            } catch (err) {
                console.error('Error loading user directories:', err);
            }
        }
    });
</script>