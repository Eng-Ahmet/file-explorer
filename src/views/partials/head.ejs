<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<% const _baseUrl='https://hwai-technology.com' ; const _title=typeof pageTitle !=='undefined' ? pageTitle
    : 'HWAI Technology | AI & Digital Innovation' ; const _desc=typeof pageDesc !=='undefined' ? pageDesc
    : 'HWAI Technology pioneers AI-powered web, mobile, and cloud solutions. We transform ideas into world-class digital products.'
    ; const _url=typeof pageUrl !=='undefined' ? pageUrl : _baseUrl; const _img=typeof pageImage !=='undefined' ?
    pageImage : '/images/icon.png' ; const _imgUrl=_img.startsWith('http') ? _img : `${_baseUrl}${_img}`; const
    _robots=typeof pageNoIndex !=='undefined' && pageNoIndex ? 'noindex, nofollow' : 'index, follow' ; const
    _lang=typeof lang !=='undefined' ? lang : 'en' ; const _locale=_lang==='ar' ? 'ar_SY' : (_lang==='es' ? 'es_ES'
    : 'en_US' ); %>
    <meta name="description" content="<%= _desc %>">
    <meta name="robots" content="<%= _robots %>">
    <meta name="author" content="HWAI Technology">
    <meta name="keywords"
        content="AI, artificial intelligence, web development, mobile apps, cloud services, digital transformation, HWAI Technology">
    <link rel="canonical" href="<%= _url %>">

    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= _url %>">
    <meta property="og:title" content="<%= _title %>">
    <meta property="og:description" content="<%= _desc %>">
    <meta property="og:image" content="<%= _imgUrl %>">
    <meta property="og:site_name" content="HWAI Technology">
    <meta property="og:locale" content="<%= _locale %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= _title %>">
    <meta name="twitter:description" content="<%= _desc %>">
    <meta name="twitter:image" content="<%= _imgUrl %>">

    <meta name="theme-color" content="#1E73BE">

    <script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "HWAI Technology",
    "url": "https://hwai-technology.com/",
    "logo": "https://hwai-technology.com/images/logo.png",
    "description": "HWAI Technology pioneers AI-powered web, mobile, and cloud solutions.",
    "sameAs": [
        "https://www.facebook.com/profile.php?id=61582849137969",
        "https://www.linkedin.com/company/hwai-technology/"
    ]
}
</script>

    <link rel="icon" type="image/png" href="/images/icon.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/js/tailwind-config.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <script src="/js/common.js"></script>
    <style>
        :root {
            --tech-blue: #38bdf8;
            --tech-purple: #818cf8;
            --bg-deep: #0B0F1A;
        }

        body {
            background: var(--bg-deep);
            color: #f1f5f9;
            font-family: 'Outfit', 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .glass {
            background: rgba(13, 17, 28, 0.9);
            backdrop-filter: blur(32px);
            -webkit-backdrop-filter: blur(32px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            box-shadow: 0 4px 40px rgba(0, 0, 0, 0.4);
        }

        .nav-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            color: #94a3b8;
            border-radius: 10px;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }

        @media (min-width: 1024px) {
            .nav-btn {
                width: auto;
                height: auto;
                padding: 0.75rem 1.25rem;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.15em;
                border-radius: 4px;
                background: rgba(255, 255, 255, 0.02);
                border-color: rgba(255, 255, 255, 0.05);
            }
        }

        .nav-btn:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
        }

        .nav-btn.active {
            background: rgba(56, 189, 248, 0.1);
            color: var(--tech-blue);
            border-color: rgba(56, 189, 248, 0.3);
        }

        .premium-btn {
            background: linear-gradient(135deg, var(--tech-blue), var(--tech-purple));
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .premium-btn:hover {
            box-shadow: 0 0 20px rgba(56, 189, 248, 0.4);
            transform: translateY(-1px);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade-in {
            animation: fadeIn 0.4s ease-out forwards;
        }

        /* Premium Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(15, 23, 42, 0.2);
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: var(--tech-blue);
        }

        .text-gradient {
            background: linear-gradient(to right, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
    </style>